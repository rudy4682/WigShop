{% comment %}
  AUDIT HEADER:
  File: snippets/meta-tags.liquid
  Purpose: SEO meta tags, Open Graph, Twitter cards, and JSON-LD structured data
  Strategy: Always use product main images (hero shots) for consistency in Google Search/Shopping
  Notes: Variant images are ignored for OG/JSON-LD to prevent swatch thumbnails from appearing in search
{% endcomment %}

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if request.page_type == 'product' and product -%}
  {%- if product.featured_media -%}
    <meta property="og:image" content="{{ product.featured_media | image_url: width: 1200, height: 630 }}">
    <meta property="og:image:alt" content="{{ product.featured_media.alt | default: product.title | escape }}">
  {%- endif -%}

  <meta property="og:description" content="{{ product.description | strip_html | truncate: 160 }}">
  <meta property="product:price:amount" content="{{ product.price | divided_by: 100.0 }}">
  <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ product.title | escape }}">
  <meta name="twitter:description" content="{{ product.description | strip_html | truncate: 160 }}">
  {% if product.featured_media %}
    <meta name="twitter:image" content="{{ product.featured_media | image_url: width: 1200, height: 630 }}">
  {% endif %}

  {%- comment -%} JSON-LD structured data for Product {%- endcomment -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | truncate: 160 | json }},
      "image": [
        {%- for image in product.images -%}
          {{ image | image_url: width: 1200 | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ],
      "sku": {{ product.variants.first.sku | json }},
      "offers": {
        "@type": "Offer",
        "availability": "{% if product.available %}http://schema.org/InStock{% else %}http://schema.org/OutOfStock{% endif %}",
        "price": {{ product.price | divided_by: 100.0 | json }},
        "priceCurrency": {{ cart.currency | json }},
        "url": {{ canonical_url | json }}
      }
    }
  </script>
{%- else -%}
  {%- if page_image -%}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200, height: 630 }}">
    <meta property="og:image:alt" content="{{ page_title | escape }}">
  {%- endif -%}

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ og_title | escape }}">
  <meta name="twitter:description" content="{{ og_description | escape }}">
  {% if page_image %}
    <meta name="twitter:image" content="{{ page_image | image_url: width: 1200, height: 630 }}">
  {% endif %}
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}

{%- comment -%} canonical — always product root URL {%- endcomment -%}
<link rel="canonical" href="{{ product.url | prepend: shop.url }}">

{%- comment -%} og:image — prefer variant featured image when URL contains id param {%- endcomment -%}
{%- assign og_image = product.featured_image -%}
{%- if request.params.id != blank -%}
  {%- assign selected_variant = product.variants | where: 'id', request.params.id | first -%}
  {%- if selected_variant and selected_variant.featured_media != null -%}
    {%- assign og_image = selected_variant.featured_media.preview_image -%}
  {%- endif -%}
{%- endif -%}

<meta property="og:image" content="{{ og_image | image_url: width: 1200, height: 630 | prepend: shop.secure_url }}">
<meta property="og:image:alt" content="{{ og_image.alt | default: product.title | escape }}">
