{% comment %}
  AUDIT HEADER — WigShop v1.0
  File: snippets/price.liquid
  Purpose:
    - Refactor price display logic for WigShop variant-first UX
    - Show "From" pricing until a variant is chosen
    - Sale badge only if discount >= admin threshold
  Dependencies: product object, settings.sale_badge_threshold
{% endcomment %}

{%- liquid
  assign sale_threshold = settings.sale_badge_threshold | default: 16

  if use_variant and request.params.id
    assign target = product.selected_or_first_available_variant
  elsif placeholder
    assign target = null
  else
    assign target = product
  endif

  assign price = target.price | default: 1999
  assign compare_at_price = target.compare_at_price
  assign available = target.available | default: false

  assign money_price = price | money
  if settings.currency_code_enabled
    assign money_price = price | money_with_currency
  endif

  if target == product and product.price_varies
    assign money_price = 'products.product.price.from_price_html' | t: price: money_price
  endif

  assign lowest_price = product.variants | map: 'price' | sort | first
  assign lowest_compare = product.variants | map: 'compare_at_price' | compact | sort | first
-%}

{%- unless target == null and placeholder == null -%}
  <div
    class="
      price
      {%- if price_class %} {{ price_class }}{% endif -%}
      {%- if available == false %} price--sold-out{% endif -%}
      {%- if compare_at_price > price and product.quantity_price_breaks_configured? != true %} price--on-sale{% endif -%}
      {%- if compare_at_price > price and product.quantity_price_breaks_configured? %} volume-pricing--sale-badge{% endif -%}
      {%- if product.price_varies == false and product.compare_at_price_varies %} price--no-compare{% endif -%}
      {%- if show_badges %} price--show-badge{% endif -%}
    "
    data-price-wrapper
  >
    <div class="price__container">
      {%- if target and request.params.id -%}
        {% comment %} Variant selected — show its price {% endcomment %}
        <div class="price__regular">
          <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.regular_price' | t }}</span>
          <span class="price-item price-item--regular">{{ money_price }}</span>
        </div>
        {% if compare_at_price > price %}
          <div class="price__sale">
            <span class="price-item price-item--sale price-item--last">{{ money_price }}</span>
            <s class="price-item price-item--regular">
              {% if settings.currency_code_enabled %}
                {{ compare_at_price | money_with_currency }}
              {% else %}
                {{ compare_at_price | money }}
              {% endif %}
            </s>
          </div>
          {% assign discount = compare_at_price | minus: price | times: 100 | divided_by: compare_at_price %}
          {% if discount >= sale_threshold %}
            <span class="badge badge--sale" data-sale-badge>Sale</span>
          {% endif %}
        {% endif %}
      {%- else -%}
        {% comment %} No variant selected — show "From" pricing {% endcomment %}
        <div class="price__regular">
          <span class="visually-hidden visually-hidden--inline">{{ 'products.product.price.regular_price' | t }}</span>
          <span class="price-item price-item--regular">From: {{ lowest_price | money }}</span>
        </div>
        {% if lowest_compare > lowest_price %}
          <div class="price__sale">
            <span class="price-item price-item--sale price-item--last">From: {{ lowest_price | money }}</span>
            <s class="price-item price-item--regular">
              {% if settings.currency_code_enabled %}
                {{ lowest_compare | money_with_currency }}
              {% else %}
                {{ lowest_compare | money }}
              {% endif %}
            </s>
          </div>
          {% assign discount = lowest_compare | minus: lowest_price | times: 100 | divided_by: lowest_compare %}
          {% if discount >= sale_threshold %}
            <span class="badge badge--sale" data-sale-badge>Sale</span>
          {% endif %}
        {% endif %}
      {%- endif -%}
    </div>

    {%- if show_badges -%}
      <span class="badge price__badge-sold-out color-{{ settings.sold_out_badge_color_scheme }}">
        {{ 'products.product.sold_out' | t }}
      </span>
    {%- endif -%}
  </div>
{%- endunless -%}
