{% comment %}
  AUDIT HEADER — WigShop v1.0
  File: snippets/variant-dropdown.liquid
  Purpose: Renders variant dropdown with "Make a selection" placeholder
  Fixes:
    - Uses translation key products.product.make_a_selection
    - Publishes optionValueSelectionChange for product-info.js
    - Replaces deprecated img_url with image_url
{% endcomment %}

<select
  id="VariantDropdown-{{ section.id }}"
  name="id"
  data-product-url="{{ product.url }}"
  aria-label="{{ 'products.product.variant_label' | t }}"
>
  <option value="">{{ 'products.product.make_selection' | t | default: 'Make a selection' }}</option>

  {%- for v in product.variants -%}
    {%- assign qty = v.inventory_quantity | default: 0 -%}
    {%- assign low_limit = settings.stock_low_threshold | default: 9 -%}
    {%- assign very_low_limit = settings.stock_very_low_threshold | default: 3 -%}
    {%- assign suffix = '' -%}
    {%- if v.available == false -%}
      {%- assign disabled_attr = 'disabled' -%}
      {%- assign suffix = ' - ' | append: ( 'products.product.unavailable' | t | default: 'Unavailable' ) -%}
    {%- else -%}
      {%- assign disabled_attr = '' -%}
      {%- if qty <= very_low_limit and qty > 0 -%}
        {%- assign suffix = ' - ' | append: ( 'products.product.very_low' | t | default: 'Very Low' ) -%}
      {%- elsif qty <= low_limit and qty > 0 -%}
        {%- assign suffix = ' - ' | append: ( 'products.product.low_stock' | t | default: 'Low Stock' ) -%}
      {%- endif -%}
    {%- endif -%}

    <option
      value="{{ v.id }}"
      data-price="{{ v.price }}"
      data-compare="{{ v.compare_at_price }}"
      data-qty="{{ qty }}"
      {{ disabled_attr }}
    >
      {{ v.title -}}
      {{- suffix }}
    </option>
  {%- endfor -%}
</select>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const select = document.getElementById('VariantDropdown-{{ section.id }}');
    if (!select) return;

    select.addEventListener('change', function () {
      const opt = select.options[select.selectedIndex];
      const selectedOptionValues = (opt?.dataset.optionValues || '').split(',').filter((v) => v !== '');

      if (window.publish && window.PUB_SUB_EVENTS) {
        window.publish(window.PUB_SUB_EVENTS.optionValueSelectionChange, {
          data: {
            event: new Event('change'),
            target: select,
            selectedOptionValues,
          },
        });
      }
    });
  });
</script>
