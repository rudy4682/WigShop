{% comment %}
  AUDIT HEADER — WigShop v1.0
  File: snippets/swatch-input.liquid
  Purpose: Renders a swatch input with WigShop data attributes
  Trigger: Used inside variant swatch loops
  Dependencies: product object, variant object, product_form_id
  Notes:
    - Includes data-option-values for parity with dropdowns
    - Publishes consistent payloads for product-info.js
    - Forwards full variant object to swatch.liquid for image + tooltip
{% endcomment %}

<input
  type="{{ type | default: 'radio' }}"
  id="{{ id }}"
  name="{{ name }}"
  value="{{ value.id | default: value }}"
  form="{{ product_form_id }}"
  class="swatch-input__input{% if visually_disabled %} visually-disabled{% endif %}"
  data-variant-swatch
  data-variant-id="{{ value.id | default: value }}"
  data-option-values="{{ value.options | join: ',' }}"
  data-inventory-quantity="{{ value.inventory_quantity | default: 0 }}"
  data-price="{{ value.price | divided_by: 100.0 }}"
  data-compare-at="{{ value.compare_at_price | divided_by: 100.0 }}"
  data-image="{{ value.featured_media | image_url: width: 600, height: 600 }}"
  {% if checked %}checked{% endif %}
  {% if disabled %}disabled{% endif %}
  {% if additional_props %}{{- additional_props -}}{% endif %}
>
<label
  for="{{ id }}"
  title="{{ value.title | default: value }}"
  class="swatch-input__label{% if shape == 'square' %} swatch-input__label--square{% endif %}"
>
  {% render 'swatch',
    swatch: swatch,
    variant: value,
    shape: shape
  %}
</label>
