{% comment %}
  AUDIT HEADER — WigShop v1.0
  File: snippets/swatch.liquid
  Purpose: Renders a swatch with variant image fallback logic
  Accepts:
    - swatch: {Object} a swatch object
    - variant: {Object} optional variant object (for featured_media + title)
    - shape: {String} swatch shape. Accepts 'square', defaults to circle.
  Notes:
    - Prefers variant.featured_media image if available
    - Falls back to swatch.image, then swatch.color, then neutral gray
    - Forces square swatches (border-radius: 0.2rem)
    - Adds hover tooltip with variant title
    - Includes visually hidden span for accessibility
  Usage:
    {% render 'swatch',
      swatch: value.swatch,
      variant: value,
      shape: 'square'
    %}
{% endcomment %}

{%- liquid
  assign swatch_shape = shape | default: 'square'
  assign swatch_style = ''
  assign swatch_focal_point = null
  assign swatch_title = null

  if variant and variant.featured_media
    assign image_url = variant.featured_media | image_url: width: 50, height: 50
    assign swatch_style = 'background-image: url(' | append: image_url | append: ');'
    assign swatch_focal_point = variant.featured_media.presentation.focal_point
    assign swatch_title = variant.title
  elsif swatch.image
    assign image_url = swatch.image | image_url: width: 50
    assign swatch_style = 'background-image: url(' | append: image_url | append: ');'
    assign swatch_focal_point = swatch.image.presentation.focal_point
    assign swatch_title = swatch.image.alt | default: swatch.color.name
  elsif swatch.color
    assign swatch_style = 'background-color: rgb(' | append: swatch.color.rgb | append: ');'
    assign swatch_title = swatch.color.name
  else
    assign swatch_style = 'background-color: #e0e0e0;'
    assign swatch_title = 'Unavailable'
  endif
-%}

<span
  class="swatch{% if swatch_shape == 'square' %} swatch--square{% endif %}"
  style="{{ swatch_style }}{% if swatch_focal_point %} --swatch-focal-point: {{ swatch_focal_point }};{% endif %}"
  title="{{ swatch_title | escape }}"
>
  <span class="visually-hidden">{{ swatch_title }}</span>
  <span class="swatch-tooltip" aria-hidden="true">{{ swatch_title }}</span>
</span>
