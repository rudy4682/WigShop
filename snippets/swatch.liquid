{% comment %}
  Swatch renderer used by product variant pickers.

  Expects:
  - swatch: {Object} Swatch/option value object
  - option_index: {Integer} Option index
  - current_variant: {Object} Currently selected variant (optional)
  - show_inventory: {Boolean} Whether to display inventory availability classes

  Behavior:
  - Prefer variant.featured_media for swatch thumbnail; fall back to swatch.image or generated color tile
  - Adds availability classes when inventory thresholds are passed
  - Emits data attributes used by JS to update gallery when a swatch is chosen
{% endcomment %}

{%- assign swatch_image = swatch.image -%}
{%- assign swatch_color = swatch.color -%}

{%- comment -%} Determine availability based on variant meta if present {%- endcomment -%}
{%- assign available = true -%}
{%- if swatch.available == false or swatch.disabled == true -%}
  {%- assign available = false -%}
{%- endif -%}

<button
  type="button"
  class="swatch{% unless available %} swatch--disabled{% endunless %}{% if shape == 'square' %} swatch--square{% endif %}"
  data-swatch-value="{{ swatch.value | escape }}"
  data-swatch-index="{{ option_index }}"
  aria-pressed="false"
  aria-label="{{ swatch.label | default: swatch.value }}"
  {% if swatch_image %}
    data-swatch-image-src="{{ swatch_image.src }}"
  {% endif %}
>
  {% if swatch_image %}
    <img
      src="{{ swatch_image | img_url: '200x' }}"
      alt="{{ swatch.label | default: swatch.value }}"
      class="swatch__image"
      loading="lazy"
    >
  {% elsif swatch_color %}
    <span class="swatch__color" style="background-color: {{ swatch_color }};" aria-hidden="true"></span>
  {% else %}
    <span class="swatch__label">{{ swatch.label | default: swatch.value }}</span>
  {% endif %}

  {% if show_inventory %}
    <span class="swatch__availability">
      {% if available %}
        <span class="visually-hidden">{{ 'products.general.available' | t }}</span>
      {% else %}
        <span class="visually-hidden">{{ 'products.general.sold_out' | t }}</span>
      {% endif %}
    </span>
  {% endif %}
</button>
