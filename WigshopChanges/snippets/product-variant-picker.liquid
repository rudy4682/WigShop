{% comment %}
  WigShop: Flexible variant picker

  Renders variant pickers with optional global override via the `variant_display` render-parameter.

  Supported values for `variant_display`:
    - "dropdown"   => Always render dropdown selects
    - "swatches"   => Prefer swatches where available, fallback to dropdown
    - "combined"   => Render a dropdown plus swatches (when swatches exist)
    - "auto" (default) => Use block.settings.picker_type behaviour
    - "none"       => Render nothing (useful when product has a single variant)

  Usage:
    {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id, variant_display: section.settings.variant_display %}

  Notes:
    - This file lives in WigshopChanges/ so you can test and iterate before applying to the live theme.
    - It delegates per-option rendering to 'product-variant-options' and 'swatch' snippets already used across the theme.
{% endcomment %}

{%- comment -%} Don't render anything for single-variant products {%- endcomment -%}
{%- if product.has_only_default_variant -%}
  {%- comment -%} Nothing to pick - bail out early {%- endcomment -%}
{%- endif -%}

{%- unless product.has_only_default_variant -%}
  {%- assign display = variant_display | default: block.settings.picker_type | default: 'auto' -%}

  {%- if display == 'none' and product.variants.size <= 1 -%}
    {%- comment -%} Explicitly requested to hide pickers for single-variant products {%- endcomment -%}
  {%- else -%}
    <variant-selects
      id="variant-selects-{{ section.id }}"
      data-section="{{ section.id }}"
      {{ block.shopify_attributes }}
    >
      {%- for option in product.options_with_values -%}
        {%- liquid
          assign swatch_count = option.values | map: 'swatch' | compact | size
          assign effective_picker = display

          if effective_picker == 'auto'
            assign effective_picker = block.settings.picker_type
          endif

          if swatch_count > 0 and block.settings.swatch_shape != 'none'
            if effective_picker == 'dropdown'
              assign option_picker = 'swatch_dropdown'
            else
              assign option_picker = effective_picker
            endif
          else
            assign option_picker = effective_picker
          endif
        -%}

        {%- if display == 'combined' -%}
          {%- comment -%} Combined mode: show a visible dropdown for accessibility/quick-select, then swatches below where available {%- endcomment -%}
          <div class="product-form__input product-form__input--combined">
            <label class="form__label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
              {{ option.name }}
            </label>

            <select
              id="Option-{{ section.id }}-{{ forloop.index0 }}"
              class="variant-select-dropdown"
              name="options[{{ option.name | escape }}]"
              form="{{ product_form_id }}"
            >
              {%- unless option.selected_value -%}
                <option value="" disabled selected hidden>
                  {{ 'products.product.make_a_selection' | t | default: 'Make a selection' }}
                </option>
              {%- endunless -%}
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: 'dropdown'
              %}
            </select>

            {%- if swatch_count > 0 and block.settings.swatch_shape != 'none' -%}
              <div class="swatch-container">
                {% render 'product-variant-options',
                  product: product,
                  option: option,
                  block: block,
                  picker_type: 'swatch'
                %}
              </div>
            {%- endif -%}
          </div>

        {%- elsif option_picker == 'swatch' or option_picker == 'swatch_dropdown' or option_picker == 'button' -%}
          {%- if option_picker == 'swatch' -%}
            <fieldset class="js product-form__input product-form__input--swatch">
              <legend class="form__label">
                {{ option.name }}:
                <span data-selected-value>
                  {{- option.selected_value -}}
                </span>
              </legend>
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: 'swatch'
              %}
            </fieldset>
          {%- elsif option_picker == 'button' -%}
            <fieldset class="js product-form__input product-form__input--pill">
              <legend class="form__label">{{ option.name }}</legend>
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: 'button'
              %}
            </fieldset>
          {%- else -%}
            <div class="product-form__input product-form__input--dropdown">
              <label class="form__label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                {{ option.name }}
              </label>
              <div class="select">
                {%- if option_picker == 'swatch_dropdown' -%}
                  <span data-selected-value class="dropdown-swatch">
                    {% render 'swatch', swatch: option.selected_value.swatch, shape: block.settings.swatch_shape %}
                  </span>
                {%- endif -%}
                <select
                  id="Option-{{ section.id }}-{{ forloop.index0 }}"
                  class="select__select"
                  name="options[{{ option.name | escape }}]"
                  form="{{ product_form_id }}"
                >
                  {%- unless option.selected_value -%}
                    <option value="" disabled selected hidden>
                      {{ 'products.product.make_a_selection' | t | default: 'Make a selection' }}
                    </option>
                  {%- endunless -%}
                  {% render 'product-variant-options',
                    product: product,
                    option: option,
                    block: block,
                    picker_type: 'dropdown'
                  %}
                </select>
                <span class="svg-wrapper">
                  {{- 'icon-caret.svg' | inline_asset_content -}}
                </span>
              </div>
            </div>
          {%- endif -%}
        {%- else -%}
          {%- comment -%} Fallback to dropdown {%- endcomment -%}
          <div class="product-form__input product-form__input--dropdown">
            <label class="form__label" for="Option-{{ section.id }}-{{ forloop.index0 }}">
              {{ option.name }}
            </label>
            <div class="select">
              <select
                id="Option-{{ section.id }}-{{ forloop.index0 }}"
                class="select__select"
                name="options[{{ option.name | escape }}]"
                form="{{ product_form_id }}"
              >
                {%- unless option.selected_value -%}
                  <option value="" disabled selected hidden>
                    {{ 'products.product.make_a_selection' | t | default: 'Make a selection' }}
                  </option>
                {%- endunless -%}
                {% render 'product-variant-options',
                  product: product,
                  option: option,
                  block: block,
                  picker_type: 'dropdown'
                %}
              </select>
              <span class="svg-wrapper">
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </span>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}

      <script type="application/json" data-selected-variant>
        {{ product.selected_or_first_available_variant | json }}
      </script>
    </variant-selects>
  {%- endif -%}
{%- endunless -%}
